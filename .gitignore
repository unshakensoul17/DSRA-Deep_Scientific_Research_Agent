# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually undesirable.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may get conflicts.
#Pipfile.lock

# poetry
#   Using Poetry, it is generally recommended to commit poetry.lock to version control
#   But we can ignore it if we choose.
# poetry.lock

# pdm
.pdm-plugins/
.pdm-python

# PEP 582; new layout for poetry and pdm
__pypackages__/

# Celery stuff
