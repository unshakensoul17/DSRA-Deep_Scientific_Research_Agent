# DSRA V2 — Staging Environment Config
APP_ENV=staging
APP_DEBUG=false
APP_SECRET_KEY=staging-secret-key-32-chars-long-or-more-for-testing
JWT_SECRET_KEY=staging-jwt-secret-key-32-chars-long-or-more-for-testing

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_RELOAD=false

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=dsra_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

OPENAI_API_KEY=sk-placeholder-key-for-staging
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

CHROMA_PERSIST_DIR=/workspace/data/chroma
EXPORT_BASE_DIR=/workspace/data/exports
LOG_LEVEL=INFO
LOG_FORMAT=json
