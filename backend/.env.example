# ============================================================
# DSRA V2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=development               # development | staging | production
APP_DEBUG=true
APP_VERSION=2.0.0
APP_SECRET_KEY=change-this-to-a-64-char-random-string-in-production

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                     # Increase in production
API_RELOAD=true                   # Set false in production

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dsra_v2
POSTGRES_USER=dsra_user
POSTGRES_PASSWORD=change-this-password
# Constructed automatically: postgresql+asyncpg://user:pass@host:port/db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── LLM Providers ───────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_DEFAULT_MODEL=gemini-1.5-pro          # Primary model
GEMINI_FALLBACK_MODEL=gemini-1.5-flash       # Used on rate limit / error
GEMINI_MAX_RETRIES=3
GEMINI_REQUEST_TIMEOUT=45                    # seconds

# ── Research Source APIs ─────────────────────────────────────
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=                    # Custom Search Engine ID

# No API key needed for: arXiv, Wikipedia, Semantic Scholar (free tier)
# PubMed — optional, increases rate limits
PUBMED_API_KEY=

# ── Vector Database (ChromaDB) ───────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=dsra_research
# For local persistent mode (development), set:
CHROMA_PERSIST_DIR=./data/chroma

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-64-char-random-string-different-from-app-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_RESEARCH_CREATE=5/minute
RATE_LIMIT_AUTH=10/minute

# ── File Storage (Exports) ───────────────────────────────────
EXPORT_BASE_DIR=./data/exports    # Where PDFs, Markdown, HTML are stored
EXPORT_MAX_FILE_AGE_DAYS=30       # Auto-cleanup after N days

# ── Research Defaults ────────────────────────────────────────
DEFAULT_MAX_ITERATIONS=3
DEFAULT_MAX_REVISIONS=2
DEFAULT_RESEARCH_DEPTH=2          # 1=shallow, 2=normal, 3=deep
DEFAULT_MAX_SOURCES_PER_QUERY=10
EVIDENCE_DEDUP_THRESHOLD=0.92     # Cosine similarity threshold for deduplication
CRITIQUE_APPROVAL_THRESHOLD=7.0   # Minimum score (out of 10) for report approval
GAP_COVERAGE_THRESHOLD=0.6        # Below this → gaps are considered critical

# ── Observability ────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json | console
