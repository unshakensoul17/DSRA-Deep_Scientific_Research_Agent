# DSRA V2 — Production Environment Config
# CRITICAL: Replace all secrets and passwords before launching in production!
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=production-secret-key-32-chars-long-or-more-change-me
JWT_SECRET_KEY=production-jwt-secret-key-32-chars-long-or-more-change-me

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Use production pg pool values
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=dsra_v2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure-prod-password-change-me

OPENAI_API_KEY=sk-prod-key-change-me
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

CHROMA_PERSIST_DIR=/workspace/data/chroma
EXPORT_BASE_DIR=/workspace/data/exports
LOG_LEVEL=WARNING
LOG_FORMAT=json
