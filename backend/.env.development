# DSRA V2 — Development Environment Config
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-32-chars-long-or-more-for-testing
JWT_SECRET_KEY=dev-jwt-secret-key-32-chars-long-or-more-for-testing

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dsra_v2
